<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.qvtu.gomoku.dao.ViewerDao">
    <resultMap id="ViewerMap" type="cn.edu.qvtu.gomoku.entity.Viewer">
        <id column="id" property="id"/>
        <result column="room_id" property="roomId"/>
        <result column="user_id" property="userId"/>
        <result column="join_time" property="joinTime"/>
    </resultMap>

    <!-- 插入观战记录（用户不重复） -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT IGNORE INTO viewer (room_id, user_id)
        VALUES (#{roomId}, #{userId})
    </insert>

    <!-- 查询房间所有观战者（时间降序） -->
    <select id="selectByRoomId" resultMap="ViewerMap">
        SELECT * FROM viewer
        WHERE room_id = #{roomId}
        ORDER BY join_time DESC
    </select>

    <!-- 查询用户观战记录 -->
    <select id="selectByUserId" resultMap="ViewerMap">
        SELECT * FROM viewer
        WHERE room_id = #{roomId} AND user_id = #{userId}
    </select>

    <!-- 统计房间观战人数 -->
    <select id="countByRoomId" resultType="int">
        SELECT COUNT(*) FROM viewer
        WHERE room_id = #{roomId}
    </select>

    <!-- 统计总观战人次 -->
    <select id="countTotalViewers" resultType="int">
        SELECT COUNT(*) FROM viewer
    </select>

    <!-- 删除房间观战者 -->
    <delete id="deleteByRoomIdAndUserId">
        DELETE FROM viewer
        WHERE room_id = #{roomId} AND user_id = #{userId}
    </delete>

    <!-- 根据房间号删除所有观战记录 -->
    <delete id="deleteByRoomId">
        DELETE FROM viewer WHERE room_id = #{roomId}
    </delete>

    <!-- 查询房间的详细观战记录 -->
    <select id="selectViewerDetailsByRoomId" resultType="map">
        SELECT
            v.id,
            v.room_id,
            v.user_id,
            v.join_time,
            u.username,
            u.nickname,
            u.score
        FROM viewer v
                 LEFT JOIN user u ON v.user_id = u.id
        WHERE v.room_id = #{roomId}
        ORDER BY v.join_time DESC
    </select>

    <!-- 统计某天观看人数 -->
    <select id="countViewersByDate" resultType="java.lang.Integer">
        SELECT COUNT(DISTINCT user_id)
        FROM viewer
        WHERE DATE(join_time) = #{date}
    </select>


</mapper>

