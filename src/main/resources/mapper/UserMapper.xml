<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.qvtu.dao.UserDao">
    <resultMap id="UserMap" type="cn.edu.qvtu.entity.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="score" property="score"/>
        <result column="status" property="status"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="StatisticsViewMap" type="cn.edu.qvtu.entity.StatisticsView">
        <result column="totalUsers" property="totalUsers"/>
        <result column="todayUsers" property="todayUsers"/>
        <result column="totalBattles" property="totalBattles"/>
        <result column="todayBattles" property="todayBattles"/>
        <result column="activeBattles" property="activeBattles"/>
        <result column="totalViewers" property="totalViewers"/>
    </resultMap>

    <!-- 插入新用户 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, password, nickname, score, status)
        VALUES (#{username}, #{password}, #{nickname}, #{score}, #{status})
    </insert>

    <!-- 根据ID查询用户 -->
    <select id="selectById" resultMap="UserMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <!-- 根据用户名查询用户 -->
    <select id="selectByUsername" resultMap="UserMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <!-- 查询所有的用户，并按照积分从大到小排序 -->
    <select id="selectAllUsers" resultMap="UserMap">
        SELECT * FROM user ORDER BY score DESC
    </select>

    <!-- 更新用户昵称 -->
    <update id="updateNickname">
        UPDATE user SET nickname = #{nickname} WHERE id = #{id}
    </update>

    <!-- 更新用户密码 -->
    <update id="updatePassword">
        UPDATE user SET password = #{password} WHERE id = #{id}
    </update>

    <!-- 更新用户积分 -->
    <update id="updateScore">
        UPDATE user SET score = #{score} WHERE id = #{id}
    </update>

    <!-- 更新用户状态 -->
    <update id="updateStatus">
        UPDATE user SET status = #{status} WHERE id = #{id}
    </update>

    <!-- 更新最后登录信息 -->
    <update id="updateLastLogin">
        UPDATE user SET last_login_time = #{lastLoginTime}, last_login_ip = #{lastLoginIp}
        WHERE id = #{id}
    </update>

    <!-- 多条件查询用户列表 -->
    <select id="selectUsersByCondition" resultMap="UserMap">
        SELECT * FROM user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 统计用户数量 -->
    <select id="countUsers" resultMap="StatisticsViewMap">
        SELECT
            COUNT(*) as totalUsers,
            COUNT(CASE WHEN DATE(create_time) = CURDATE() THEN 1 END) as todayUsers
        FROM user
    </select>


    <!-- 在 UserMapper.xml 中添加 -->
    <!-- 批量更新用户信息（不更新密码） -->
    <update id="updateUserInfo" parameterType="cn.edu.qvtu.entity.User">
        UPDATE user
        <set>
            <if test="nickname != null and nickname != ''">nickname = #{nickname},</if>
            <if test="score != null">score = #{score},</if>
            <if test="status != null">status = #{status},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="lastLoginIp != null and lastLoginIp != ''">last_login_ip = #{lastLoginIp},</if>
        </set>
        WHERE id = #{id}
    </update>
</mapper>

