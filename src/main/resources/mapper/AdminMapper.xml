<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.qvtu.dao.AdminDao">
    <resultMap id="AdminMap" type="cn.edu.qvtu.entity.Admin">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="nickname" property="nickname"/>
        <result column="status" property="status"/>
        <result column="role" property="role"/>
        <result column="last_login_time" property="lastLoginTime"/>
        <result column="last_login_ip" property="lastLoginIp"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- 插入管理员 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO admin (username, password, nickname, status, role)
        VALUES (#{username}, #{password}, #{nickname}, #{status}, #{role})
    </insert>

    <!-- 根据用户名查询管理员 -->
    <select id="selectByUsername" resultMap="AdminMap">
        SELECT * FROM admin WHERE username = #{username}
    </select>

    <!-- 根据ID查询管理员 -->
    <select id="selectById" resultMap="AdminMap">
        SELECT * FROM admin WHERE id = #{id}
    </select>

    <!-- 查询所有管理员 -->
    <select id="selectAll" resultMap="AdminMap">
        SELECT * FROM admin ORDER BY create_time DESC
    </select>

    <!-- 多条件查询管理员列表（带分页） -->
    <select id="selectByConditionWithPage" resultMap="AdminMap">
        SELECT * FROM admin
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="role != null">
                AND role = #{role}
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- 多条件查询管理员列表（不分页） -->
    <select id="selectByCondition" resultMap="AdminMap">
        SELECT * FROM admin
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="role != null">
                AND role = #{role}
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 统计管理员数量 -->
    <select id="countByCondition" resultType="int">
        SELECT COUNT(*) FROM admin
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="nickname != null and nickname != ''">
                AND nickname LIKE CONCAT('%', #{nickname}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="role != null">
                AND role = #{role}
            </if>
            <if test="startTime != null">
                AND create_time >= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <!-- 更新管理员信息 -->
    <update id="update">
        UPDATE admin
        <set>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="nickname != null and nickname != ''">nickname = #{nickname},</if>
            <if test="status != null">status = #{status},</if>
            <if test="role != null">role = #{role},</if>
            <if test="lastLoginTime != null">last_login_time = #{lastLoginTime},</if>
            <if test="lastLoginIp != null and lastLoginIp != ''">last_login_ip = #{lastLoginIp},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <!-- 更新最后登录信息 -->
    <update id="updateLastLogin">
        UPDATE admin SET last_login_time = #{lastLoginTime}, last_login_ip = #{lastLoginIp}
        WHERE id = #{id}
    </update>

    <!-- 删除管理员 -->
    <delete id="delete">
        DELETE FROM admin WHERE id = #{id}
    </delete>

    <!-- 批量删除管理员 -->
    <delete id="deleteByIds">
        DELETE FROM admin WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>

