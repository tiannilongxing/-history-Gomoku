<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.edu.qvtu.dao.BookDao">

    <resultMap id="BookResultMap" type="cn.edu.qvtu.entity.Book">
        <id property="isbn" column="isbn"/>
        <result property="title" column="title"/>
        <result property="author" column="author"/>
        <result property="publisher" column="publisher"/>
        <result property="publishDate" column="publish_date"/>
        <result property="price" column="price"/>
        <result property="stockQuantity" column="stock_quantity"/>
        <result property="status" column="status"/>
    </resultMap>

<!--    @Results({-->
<!--        @Result(property="publishDate", column="publish_date"),-->
<!--        @Result(property="stockQuantity", column="stock_quantity"),-->
<!--    })-->

    <insert id="insert" parameterType="cn.edu.qvtu.entity.Book">
        INSERT INTO book (isbn, title, author, publisher, publish_date, price, stock_quantity, status)
        VALUES (#{isbn}, #{title}, #{author}, #{publisher}, #{publishDate}, #{price}, #{stockQuantity}, #{status})
    </insert>

    <update id="update" parameterType="cn.edu.qvtu.entity.Book">
        UPDATE book
        SET title = #{title},
            author = #{author},
            publisher = #{publisher},
            publish_date = #{publishDate},
            price = #{price},
            stock_quantity = #{stockQuantity},
            status = #{status}
        WHERE isbn = #{isbn}
    </update>
<!--    selectByIsbn方法中，我们传入一个String类型的参数，那么就可以用parameterType="java.lang.String"来指定。-->
    <delete id="delete" parameterType="java.lang.String">
        DELETE FROM book WHERE isbn = #{isbn}
    </delete>

    <select id="selectByIsbn" parameterType="java.lang.String" resultMap="BookResultMap">
        SELECT * FROM book WHERE isbn = #{isbn}
    </select>

    <select id="selectAll" resultMap="BookResultMap">
        SELECT * FROM book ORDER BY isbn
    </select>

    <select id="selectByTitle" parameterType="java.lang.String" resultMap="BookResultMap">
        <bind name="title" value="'%' + keyword + '%'"/>
        SELECT * FROM book WHERE title LIKE #{title}
    </select>


    <select id="countByIsbn" parameterType="java.lang.String" resultType="int">
        SELECT COUNT(*) FROM book WHERE isbn = #{isbn}
    </select>

</mapper>

